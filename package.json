{
  "name": "goodbye-wrapped",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "encrypt-data": "openssl enc -aes-256-cbc -pbkdf2 -iter 600000 -salt -in data.json -out data.json.enc",
    "decrypt-data": "openssl enc -d -aes-256-cbc -pbkdf2 -iter 600000 -in data.json.enc -out data.json"
  },
  "dependencies": {
    "html-to-image": "^1.11.13",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  }
}
